    <!-- ==================== 畫面 2：廚房工作檯 ==================== -->
    <div id="screen-game" class="hidden flex-1 flex flex-col justify-between p-4 z-10 relative">
      <!-- 頂部進度條 -->
      <div class="bg-white/80 backdrop-blur-sm rounded-2xl p-3 border-2 border-orange-100 flex justify-between items-center shadow-sm">
        <div>
          <span class="text-xs text-amber-600 font-bold">目前進度</span>
          <div id="step-title" class="text-sm font-bold text-amber-900">步驟 1：選擇下一步</div>
