      </div>

      <div class="mb-8">
        <button id="btn-start" class="w-full py-4 bg-gradient-to-r from-orange-400 to-amber-500 hover:from-orange-500 hover:to-amber-600 text-white font-bold text-lg rounded-2xl shadow-lg transition-all transform active:scale-95 border-b-4 border-amber-700">
