  <!-- MathJax Configuration & Script for LaTeX rendering -->
  <script>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']]
      },
      options: {
        skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre']
      }
    };
  </script>
  <script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>

  <style>
    body {
      font-family: 'Quicksand', 'Noto Sans TC', sans-serif;
      user-select: none;
    }
    /* 基礎動畫 */
    @keyframes bounce-slow {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }
    .animate-bounce-slow {
      animation: bounce-slow 2s infinite ease-in-out;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-5px) rotate(1deg); }
    }
    .animate-float {
      animation: float 3s infinite ease-in-out;
    }
    @keyframes bubble {
      0% { transform: translateY(0) scale(0.8); opacity: 0; }
      50% { opacity: 0.8; }
      100% { transform: translateY(-40px) scale(1.2); opacity: 0; }
    }
    .bubble-particle {
      position: absolute;
      background: rgba(255, 255, 255, 0.6);
      border-radius: 50%;
      pointer-events: none;
      animation: bubble 1.5s infinite ease-out;
    }
    /* 加熱蒸汽動畫 */
    @keyframes steam {
      0% { transform: translateY(0) scaleX(1); opacity: 0; }
      50% { opacity: 0.4; }
      100% { transform: translateY(-30px) scaleX(1.3); opacity: 0; }
    }
    .steam-line {
      animation: steam 2s infinite ease-out;
    }
  </style>
</head>
<body class="bg-amber-50 text-stone-800 min-h-screen flex items-center justify-center p-2 sm:p-4">

  <!-- 遊戲主容器 -->
  <div id="game-container" class="w-full max-w-md bg-orange-100/70 border-4 border-orange-200 rounded-3xl shadow-2xl overflow-hidden relative aspect-[3/4] flex flex-col justify-between">
    
    <!-- 背景裝飾（溫馨廚房風） -->
    <div class="absolute inset-0 bg-[radial-gradient(#fed7aa_1px,transparent_1px)] [background-size:16px_16px] opacity-40 pointer-events-none"></div>

    <!-- ==================== 畫面 1：遊戲主選單 ==================== -->
    <div id="screen-main" class="flex-1 flex flex-col justify-between p-6 z-10 text-center">
      <div class="mt-8">
        <span class="bg-amber-200 text-amber-800 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">療癒化學廚房</span>
        <h1 class="text-3xl sm:text-4xl font-extrabold text-amber-900 mt-3 tracking-tight drop-shadow-sm animate-bounce-slow">
          碳酸鈣能變豆花？！
        </h1>
        <p class="text-amber-700 text-sm mt-2">一場美味與科學交織的神奇凝固實驗</p>
      </div>

      <!-- 可愛中心插圖 -->
      <div class="flex justify-center my-4 relative">
        <div class="relative w-40 h-40 animate-float">
          <!-- 帶有表情的可愛豆花碗 -->
          <svg viewBox="0 0 100 100" class="w-full h-full">
            <!-- 桌子陰影 -->
            <ellipse cx="50" cy="85" rx="35" ry="8" fill="#fcd34d" opacity="0.4"/>
            <!-- 碗 -->
            <path d="M15,50 Q15,80 50,80 Q85,80 85,50 Z" fill="#fff" stroke="#fdba74" stroke-width="4" />
            <rect x="10" y="45" width="80" height="8" rx="4" fill="#ffedd5" stroke="#fdba74" stroke-width="3" />
            <!-- 豆花本體 -->
            <ellipse cx="50" cy="46" rx="33" ry="10" fill="#fef3c7" />
            <!-- 糖水 -->
            <path d="M25,47 Q50,54 75,47" stroke="#d97706" stroke-width="3" fill="none" />
            <!-- 可愛紅豆 -->
            <circle cx="40" cy="45" r="4" fill="#991b1b" />
            <circle cx="46" cy="43" r="3.5" fill="#991b1b" />
            <circle cx="36" cy="48" r="3" fill="#991b1b" />
            <!-- 可愛眼睛與微笑 -->
            <circle cx="43" cy="62" r="3" fill="#78350f" />
